\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The Tracy--Widom regime. Left: $\Cov  (N_1,N_2)\sim T^{1/2}$, the uncorrelatedness of Conjecture~\ref {conj:cov}. Middle: the marginal current against the GUE Tracy--Widom law $F_2$ at $T=3.3\times 10^4$. Right: $n$--independence --- the standardised marginals at $n=2$ and $n=13$ collapse onto $F_2$.}}{29}{figure.2}\protected@file@percent }
\newlabel{fig:cov}{{2}{29}{The Tracy--Widom regime. Left: $\Cov (N_1,N_2)\sim T^{1/2}$, the uncorrelatedness of Conjecture~\ref {conj:cov}. Middle: the marginal current against the GUE Tracy--Widom law $F_2$ at $T=3.3\times 10^4$. Right: $n$--independence --- the standardised marginals at $n=2$ and $n=13$ collapse onto $F_2$}{figure.2}{}}
